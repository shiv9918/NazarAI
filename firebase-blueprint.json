{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["citizen", "department", "admin"] },
        "department": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Report": {
      "title": "Report",
      "description": "Issue report submitted by a citizen",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "severity": { "type": "number" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "location": { "type": "string" },
        "ward": { "type": "string" },
        "department": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["reported", "in_progress", "resolved"] },
        "reportedAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["type", "lat", "lng", "location", "department", "status", "reportedAt", "uid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Issue reports"
    }
  }
}
